VIRTUOSO_ADMIN_USER=admin
VIRTUOSO_ADMIN_PASSWORD=admin
VIRTUOSO_RW_USER=rw
VIRTUOSO_RW_PASSWORD=rw
VIRTUOSO_RO_USER=ro
VIRTUOSO_RO_PASSWORD=ro
DBA_PASSWORD=dba
# run on dedicated ports so it can coexist with the Qanary triplestore Virtuoso
# (1111/8890) on the host network
VIRT_Parameters_ServerPort=1112
VIRT_HTTPServer_ServerPort=8891
# SPARQL queries without an explicit FROM (as generated by QB-Wikidata) resolve
# against this default graph, which is where the loader puts the Wikidata subset
VIRT_SPARQL_DefaultGraph=urn:wikidata
